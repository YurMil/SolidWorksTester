<?xml version="1.0" encoding="utf-8"?>
<!--
  Publishes a self-contained single-file EXE into the project root folder.
  Usage: .\publish.bat
         or: dotnet publish SolidWorksTester.csproj -c Release -r win-x64 -p:PublishProfile=StandaloneWin64 -p:Platform=x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- WebView2 / satellite content must extract from single-file bundle -->
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Trimming breaks SOLIDWORKS COM interop — keep false -->
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <PublishDir>$(MSBuildProjectDirectory)\</PublishDir>
    <!-- Do not copy NuGet XML docs into the project root -->
    <AllowedReferenceRelatedFileExtensions>
      <!-- empty: skip .xml/.pdb related files -->
    </AllowedReferenceRelatedFileExtensions>
  </PropertyGroup>
</Project>
